# HiveDoctor build artifacts and deps. These are PRODUCED by the build/install,
# never committed. The published tarball is assembled by `npm pack` (prepack ->
# `npm run build`) from a clean tree; nothing here belongs in git.
#
# The root .gitignore's `/dist/` is root-anchored and does NOT cover
# hivedoctor/dist, and its `**/bundle/` already covers hivedoctor/bundle, but we
# enumerate both here so this package is self-describing and a `git add
# hivedoctor/` can never stage a stray build artifact.

# tsc emit (the intermediate the esbuild step consumes).
dist/

# esbuild output: the single self-contained bin bundle + its ESM marker.
bundle/

# Installed dependencies (dev-only; the lockfile is committed, the tree is not).
node_modules/

# Coverage output from `vitest run --coverage`.
coverage/
