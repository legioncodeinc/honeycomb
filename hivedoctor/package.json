{
  "name": "@legioncodeinc/hivedoctor",
  "version": "0.1.1",
  "description": "HiveDoctor: a deliberately tiny, dependency-light, self-healing watchdog that keeps the Honeycomb primary daemon alive and reports when it cannot.",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "bin": {
    "hivedoctor": "bundle/cli.js"
  },
  "files": [
    "bundle/cli.js",
    "bundle/package.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && node esbuild.config.mjs",
    "bundle": "node esbuild.config.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "ci": "npm run typecheck && npm run test",
    "pack:check": "node scripts/pack-check.mjs",
    "prepack": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.2.6",
    "esbuild": "^0.28.1",
    "typescript": "^5.7.0",
    "vitest": "^3.2.6"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/legioncodeinc/honeycomb.git",
    "directory": "hivedoctor"
  }
}
