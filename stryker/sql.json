{
	"$schema": "../node_modules/@stryker-mutator/core/schema/stryker-schema.json",
	"packageManager": "npm",
	"testRunner": "vitest",
	"vitest": { "configFile": "stryker/vitest.sql.config.ts" },
	"reporters": ["clear-text", "json"],
	"jsonReporter": { "fileName": "reports/mutation/sql.json" },
	"mutate": ["src/daemon/storage/sql.ts"],
	"concurrency": 4,
	"timeoutMS": 60000,
	"timeoutFactor": 3,
	"tempDirName": ".stryker-tmp-sql",
	"cleanTempDir": true,
	"coverageAnalysis": "perTest"
}
