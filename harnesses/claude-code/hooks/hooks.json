{
	"description": "Honeycomb memory — captures session activity and renders prior context via the local Honeycomb daemon (PRD-021c reference harness)",
	"hooks": {
		"SessionStart": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "node \"${CLAUDE_PLUGIN_ROOT}/bundle/index.js\"",
						"timeout": 30
					}
				]
			}
		],
		"UserPromptSubmit": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "node \"${CLAUDE_PLUGIN_ROOT}/bundle/index.js\" --honeycomb-recall",
						"timeout": 10
					}
				]
			},
			{
				"hooks": [
					{
						"type": "command",
						"command": "node \"${CLAUDE_PLUGIN_ROOT}/bundle/index.js\"",
						"timeout": 10,
						"async": true
					}
				]
			}
		],
		"PreToolUse": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "node \"${CLAUDE_PLUGIN_ROOT}/bundle/index.js\"",
						"timeout": 60
					}
				]
			}
		],
		"PostToolUse": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "node \"${CLAUDE_PLUGIN_ROOT}/bundle/index.js\"",
						"timeout": 15,
						"async": true
					}
				]
			}
		],
		"Stop": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "node \"${CLAUDE_PLUGIN_ROOT}/bundle/index.js\"",
						"timeout": 30,
						"async": true
					}
				]
			}
		],
		"SubagentStop": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "node \"${CLAUDE_PLUGIN_ROOT}/bundle/index.js\"",
						"timeout": 30,
						"async": true
					}
				]
			}
		],
		"SessionEnd": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "node \"${CLAUDE_PLUGIN_ROOT}/bundle/index.js\"",
						"timeout": 60
					}
				]
			}
		]
	}
}
